#!/usr/bin/env bash
# pre-push hook — Runs e2e BPF overhead test when BPF-related files change.
#
# Detected patterns:
#   src/bpfGenerator/**  — DSL program definitions
#   bpf/**               — BPF headers and compiled objects
#   jni/**               — JNI bridge (BPF ↔ JVM)
#
# Install:
#   git config core.hooksPath .githooks
#
# Skip (emergency):
#   git push --no-verify

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${CYAN}[pre-push]${NC} $*"; }
warn()  { echo -e "${YELLOW}[pre-push]${NC} $*"; }
pass()  { echo -e "${GREEN}[pre-push]${NC} $*"; }
fail()  { echo -e "${RED}[pre-push]${NC} $*"; }

BPF_PATTERNS="src/bpfGenerator/ bpf/ jni/"

# Read stdin: <local ref> <local sha> <remote ref> <remote sha>
while read -r local_ref local_sha remote_ref remote_sha; do
    # Skip delete pushes
    if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
        continue
    fi

    # For new branches, compare against main
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        remote_sha=$(git rev-parse origin/main 2>/dev/null || echo "")
        if [ -z "$remote_sha" ]; then
            info "No origin/main found, skipping BPF check"
            continue
        fi
    fi

    # Get changed files between remote and local
    changed_files=$(git diff --name-only "$remote_sha" "$local_sha" 2>/dev/null || true)
    if [ -z "$changed_files" ]; then
        continue
    fi

    # Check if any BPF-related files changed
    bpf_changed=false
    for pattern in $BPF_PATTERNS; do
        if echo "$changed_files" | grep -q "^${pattern}"; then
            bpf_changed=true
            break
        fi
    done

    if [ "$bpf_changed" = false ]; then
        continue
    fi

    # Show which BPF files changed
    info "BPF-related files changed:"
    for pattern in $BPF_PATTERNS; do
        echo "$changed_files" | grep "^${pattern}" | while read -r f; do
            echo "  $f"
        done
    done

    # Check minikube is running
    if ! minikube status --format='{{.Host}}' 2>/dev/null | grep -q "Running"; then
        warn "Minikube is not running. Start it with: minikube start"
        warn "Skipping BPF e2e test (run manually: ./e2e/e2e-test.sh)"
        exit 0
    fi

    info "Running BPF e2e test on minikube..."
    echo ""

    # Point docker to minikube and run e2e test
    if eval $(minikube docker-env 2>/dev/null) && ./e2e/e2e-test.sh --cleanup; then
        echo ""
        pass "BPF e2e test passed — push allowed"
    else
        echo ""
        fail "BPF e2e test FAILED — push blocked"
        fail "Fix the issue and retry, or skip with: git push --no-verify"
        exit 1
    fi
done

exit 0
