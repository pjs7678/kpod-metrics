      "title": "DNS Query Rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(kpod_dns_requests_total{namespace=~\"$namespace\", pod=~\"$pod\", node=~\"$node\"}[5m])) by (pod, qtype)",
          "legendFormat": "{{pod}} - {{qtype}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
