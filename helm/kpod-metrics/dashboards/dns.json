          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Value"
          }
        ]
      },
      "title": "Top Domains",
      "type": "table",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "includeByName": {},
            "indexByName": {
              "domain": 0,
              "pod": 1,
              "Value": 2
            },
            "renameByName": {}
          }
        }
      ],
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "topk(20, sum by (domain, pod) (rate(kpod_dns_top_domains_total{namespace=~\"$namespace\", pod=~\"$pod\"}[5m])))",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
